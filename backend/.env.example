# Copy to backend/.env and fill in.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/?appName=Cluster
DATABASE_NAME=markupmarkdown-dev

# Generate with: openssl rand -hex 32
MARKUPMARKDOWN_ENCRYPTION_KEY=

# Optional: GitHub OAuth (see README §GitHub OAuth setup)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
